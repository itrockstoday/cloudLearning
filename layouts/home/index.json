{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "date" .Date "permalink" .Permalink "content" .Plain "summary" .Summary) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
